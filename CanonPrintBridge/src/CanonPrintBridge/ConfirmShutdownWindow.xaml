<Window x:Class="CanonPrintBridge.ConfirmShutdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершить работу?"
        Icon="pack://application:,,,/printer-xp-icon.ico"
        SizeToContent="Height" Width="430" ResizeMode="NoResize"
        FontFamily="{StaticResource Font}" FontSize="13" Foreground="{StaticResource Tx}"
        Background="{StaticResource Card}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <Geometry x:Key="IcoWarn2">M12 4 L21 20 H3 Z M12 10 V14 M12 17.5 H12.01</Geometry>
        <Geometry x:Key="IcoPower2">M12 4 V12 M7.5 7 A7 7 0 1 0 16.5 7</Geometry>
    </Window.Resources>
    <StackPanel>
        <StackPanel Margin="24,24,24,18">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource WarnBg}"
                        VerticalAlignment="Center">
                    <Path Data="{StaticResource IcoWarn2}" Stroke="{StaticResource Warn}" StrokeThickness="1.8"
                          Width="20" Height="20" Stretch="Uniform"/>
                </Border>
                <TextBlock Text="Завершить работу?" Margin="12,0,0,0" VerticalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Tx}"/>
            </StackPanel>
            <TextBlock TextWrapping="Wrap" FontSize="13.5" LineHeight="21" Foreground="{StaticResource Tx2}"
                       Text="Фоновая виртуальная машина и Windows XP будут выключены, принтер станет недоступен. Незавершённое задание печати будет прервано. Индикаторы вернутся в исходное (серое) состояние."/>
        </StackPanel>
        <Border Background="{StaticResource Card}" Padding="24,0,24,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="Cancel_Click" IsCancel="True"/>
                <Button Style="{StaticResource DangerButton}" Margin="10,0,0,0" Click="Confirm_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoPower2}" Stroke="White" StrokeThickness="1.8"
                              Width="16" Height="16" Stretch="Uniform"/>
                        <TextBlock Text="Завершить работу" Margin="7,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>

<Window x:Class="CanonPrintBridge.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:CanonPrintBridge.Services"
        Title="{loc:Loc settings_title}"
        Icon="pack://application:,,,/printer-xp-icon.ico"
        Height="560" Width="620" MinWidth="520" MinHeight="480"
        FontFamily="{StaticResource Font}" FontSize="13" Foreground="{StaticResource Tx}"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <Geometry x:Key="IcoInfo2">M12 3.5 A8.5 8.5 0 1 0 12.01 3.5 Z M12 11 V16 M12 8 H12.01</Geometry>
        <Style x:Key="Fld" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- info -->
                <Border Background="{StaticResource InfoBg}" BorderBrush="{StaticResource InfoBd}"
                        BorderThickness="1" CornerRadius="8" Padding="13,11">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoInfo2}" Stroke="{StaticResource Accent}" StrokeThickness="1.8"
                              Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,0,0"/>
                        <TextBlock TextWrapping="Wrap" Margin="10,0,0,0" MaxWidth="500" FontSize="12"
                                   Foreground="{StaticResource Tx2}"
                                   Text="{loc:Loc settings_info}"/>
                    </StackPanel>
                </Border>

                <!-- Общие папки -->
                <Border Style="{StaticResource CardPanel}" Padding="15" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc settings_shared_folders}" Style="{StaticResource SectionHeader}" Margin="0,0,0,13"/>
                        <TextBlock Text="{loc:Loc settings_shared}" Style="{StaticResource Fld}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SharedBox" Style="{StaticResource PathField}"/>
                            <Button Grid.Column="1" Content="{loc:Loc btn_browse}" Margin="8,0,0,0" Height="32"
                                    Click="BrowseShared_Click"/>
                        </Grid>

                        <TextBlock Text="{loc:Loc settings_queue}" Style="{StaticResource Fld}" Margin="0,13,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="QueueBox" Style="{StaticResource PathField}"/>
                            <Button Grid.Column="1" Content="{loc:Loc btn_browse}" Margin="8,0,0,0" Height="32"
                                    Click="BrowseQueue_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Виртуальная машина -->
                <Border Style="{StaticResource CardPanel}" Padding="15" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc settings_vm_section}" Style="{StaticResource SectionHeader}" Margin="0,0,0,13"/>
                        <TextBlock Text="{loc:Loc settings_vm_name}" Style="{StaticResource Fld}"/>
                        <TextBox x:Name="VmNameBox" Style="{StaticResource PathField}"/>

                        <TextBlock Text="{loc:Loc settings_vbox_path}" Style="{StaticResource Fld}" Margin="0,13,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="VBoxBox" Style="{StaticResource PathField}"/>
                            <Button Grid.Column="1" Content="{loc:Loc btn_browse}" Margin="8,0,0,0" Height="32"
                                    Click="BrowseVBox_Click"/>
                        </Grid>

                        <TextBlock Text="{loc:Loc settings_launcher}" Style="{StaticResource Fld}" Margin="0,13,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LauncherBox" Style="{StaticResource PathField}"/>
                            <Button Grid.Column="1" Content="{loc:Loc btn_browse}" Margin="8,0,0,0" Height="32"
                                    Click="BrowseLauncher_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Язык интерфейса -->
                <Border Style="{StaticResource CardPanel}" Padding="15" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc settings_language}" Style="{StaticResource SectionHeader}" Margin="0,0,0,13"/>
                        <ComboBox x:Name="LanguageBox" Width="200" HorizontalAlignment="Left"
                                  SelectionChanged="Language_SelectionChanged">
                            <ComboBoxItem Content="Русский" Tag="ru"/>
                            <ComboBoxItem Content="English" Tag="en"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- footer -->
        <Border Grid.Row="1" Background="{StaticResource Mica}" BorderBrush="{StaticResource Stroke}"
                BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <Button Content="{loc:Loc btn_verify}" HorizontalAlignment="Left" Click="Verify_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{loc:Loc btn_save}" Style="{StaticResource AccentButton}" Padding="18,0" Click="Save_Click"/>
                    <Button Content="{loc:Loc btn_cancel}" Margin="10,0,0,0" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

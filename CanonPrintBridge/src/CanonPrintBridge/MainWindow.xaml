<Window x:Class="CanonPrintBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Canon Print Bridge — печать на LBP-1120"
        Icon="pack://application:,,,/printer-xp-icon.ico"
        Height="640" Width="470" MinWidth="446" MinHeight="560"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop"
        FontFamily="{StaticResource Font}" FontSize="13" Foreground="{StaticResource Tx}"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Icon geometries (24x24, stroke-based) -->
        <Geometry x:Key="IcoPrinter">M7 9 V4 H17 V9 M4 10.5 A1.5 1.5 0 0 1 5.5 9 H18.5 A1.5 1.5 0 0 1 20 10.5 V14.5 A1.5 1.5 0 0 1 18.5 16 H5.5 A1.5 1.5 0 0 1 4 14.5 Z M7 14 H17 V20 H7 Z</Geometry>
        <Geometry x:Key="IcoFolder">M3 7 A2 2 0 0 1 5 5 H9 L11 7 H17 A2 2 0 0 1 19 9 V10 M3.5 10 H19.5 L17.5 18 A1 1 0 0 1 16.5 18.8 H4.7 A1 1 0 0 1 3.7 18 Z</Geometry>
        <Geometry x:Key="IcoGear">M12 8.8 A3.2 3.2 0 1 0 12.01 8.8 Z M12 3.4 V5.6 M12 18.4 V20.6 M4.6 7.1 L6.5 8.2 M17.5 15.8 L19.4 16.9 M4.6 16.9 L6.5 15.8 M17.5 8.2 L19.4 7.1 M3.4 12 H5.6 M18.4 12 H20.6</Geometry>
        <Geometry x:Key="IcoPreview">M5 4 H19 A2 2 0 0 1 21 6 V18 A2 2 0 0 1 19 20 H5 A2 2 0 0 1 3 18 V6 A2 2 0 0 1 5 4 Z M14 4 V20</Geometry>
        <Geometry x:Key="IcoPower">M12 4 V12 M7.5 7 A7 7 0 1 0 16.5 7</Geometry>
        <Geometry x:Key="IcoClose">M6 6 L18 18 M18 6 L6 18</Geometry>
        <Geometry x:Key="IcoDoc">M7 3 H14 L19 8 V21 A1 1 0 0 1 18 22 H7 A1 1 0 0 1 6 21 V4 A1 1 0 0 1 7 3 Z M14 3 V8 H19</Geometry>
        <Geometry x:Key="IcoCheck">M5 12.5 L9.5 17 L19 7</Geometry>
        <Geometry x:Key="IcoInfo">M12 3.5 A8.5 8.5 0 1 0 12.01 3.5 Z M12 11 V16 M12 8 H12.01</Geometry>
        <Geometry x:Key="IcoWarn">M12 4 L21 20 H3 Z M12 10 V14 M12 17.5 H12.01</Geometry>
        <Geometry x:Key="IcoLock">M5 10 H19 V19 H5 Z M8 10 V8 A4 4 0 0 1 16 8 V10</Geometry>
        <Geometry x:Key="IcoUpload">M12 16 V4 M8 8 L12 4 L16 8 M4 16 V18 A2 2 0 0 0 6 20 H18 A2 2 0 0 0 20 18 V16</Geometry>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0" Background="{StaticResource Card2}" BorderBrush="{StaticResource Stroke}"
                BorderThickness="0,0,0,1">
            <Grid Height="50" Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="Browse_Click" ToolTip="Открыть PDF">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IcoFolder}" Stroke="{StaticResource Tx}" StrokeThickness="1.6"
                                  Width="17" Height="17" Stretch="Uniform"/>
                            <TextBlock Text="Открыть…" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PrintButton" Style="{StaticResource AccentButton}" Margin="8,0,0,0"
                            Click="Print_Click" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IcoPrinter}" Stroke="White" StrokeThickness="1.6"
                                  Width="17" Height="17" Stretch="Uniform"/>
                            <TextBlock Text="Печать" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="PreviewButton" Style="{StaticResource SubtleButton}" Click="Preview_Click"
                            ToolTip="Показать предпросмотр">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IcoPreview}" Stroke="{StaticResource Tx2}" StrokeThickness="1.6"
                                  Width="17" Height="17" Stretch="Uniform"/>
                            <TextBlock Text="Предпросмотр" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Click="Shutdown_Click" ToolTip="Завершить работу (выключить ВМ)">
                        <Path Data="{StaticResource IcoPower}" Stroke="{StaticResource Tx2}" StrokeThickness="1.6"
                              Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Click="Settings_Click" ToolTip="Настройки">
                        <Path Data="{StaticResource IcoGear}" Stroke="{StaticResource Tx2}" StrokeThickness="1.5"
                              Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Body: main | splitter | preview ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="430"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Main scroll area -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>

                    <!-- Empty state (no file) -->
                    <StackPanel x:Name="EmptyState">
                        <Border BorderBrush="{StaticResource Stroke2}" BorderThickness="2" CornerRadius="10"
                                Background="{StaticResource Card}" Padding="24,34">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="52" Height="52" CornerRadius="12" Background="{StaticResource InfoBg}"
                                        HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IcoUpload}" Stroke="{StaticResource Accent}" StrokeThickness="1.5"
                                          Width="26" Height="26" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="Перетащите PDF сюда" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Tx}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                <TextBlock Text="или выберите файл на диске — только *.pdf" FontSize="13"
                                           Foreground="{StaticResource Tx3}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                <Button Style="{StaticResource AccentButton}" Content="Выбрать файл…" Margin="0,14,0,0"
                                        HorizontalAlignment="Center" Padding="18,0" Click="Browse_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- warn + launcher (shown while VM not running) — independent of file state -->
                    <StackPanel x:Name="LauncherPanel" Margin="0,13,0,0">
                        <Border Background="{StaticResource WarnBg}" BorderBrush="{StaticResource WarnBd}"
                                BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IcoWarn}" Stroke="{StaticResource Warn}" StrokeThickness="1.8"
                                      Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                <TextBlock TextWrapping="Wrap" Margin="9,0,0,0" MaxWidth="330"
                                           FontSize="12" Foreground="{StaticResource Tx2}"
                                           Text="Принтер не запущен. Нажмите «Запустить принтер (VM)», пока выбираете файл — XP поднимется за ~30–60 с."/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="LauncherButton" Click="Launcher_Click" Margin="0,11,0,0" Height="38"
                                HorizontalContentAlignment="Center"
                                Background="{StaticResource InfoBg}" BorderBrush="{StaticResource Accent}"
                                Foreground="{StaticResource Accent}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IcoPower}" Stroke="{StaticResource Accent}" StrokeThickness="1.8"
                                      Width="17" Height="17" Stretch="Uniform"/>
                                <TextBlock Text="Запустить принтер (VM)" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- File card (file chosen) -->
                    <Border x:Name="FileCard" Style="{StaticResource CardPanel}" Padding="13,11" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="6"
                                    Background="{StaticResource LostBg}" VerticalAlignment="Center">
                                <Path Data="{StaticResource IcoDoc}" Stroke="{StaticResource Lost}" StrokeThickness="1.6"
                                      Width="18" Height="18" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                <TextBlock x:Name="FileName" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource Tx}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="FileMeta" FontFamily="{StaticResource Mono}" FontSize="12"
                                           Foreground="{StaticResource Tx3}" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28"
                                    Foreground="{StaticResource Tx3}" Click="ClearFile_Click" ToolTip="Убрать файл">
                                <Path Data="{StaticResource IcoClose}" Stroke="{StaticResource Tx3}" StrokeThickness="1.8"
                                      Width="15" Height="15" Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Hidden PdfPathBox keeps the existing contract (holds full path) -->
                    <TextBox x:Name="PdfPathBox" Visibility="Collapsed" Height="0"/>

                    <!-- Readiness -->
                    <Border Style="{StaticResource CardPanel}" Padding="14,6" Margin="0,14,0,0">
                        <StackPanel>
                            <Grid Margin="0,10,0,8">
                                <TextBlock Text="ГОТОВНОСТЬ" Style="{StaticResource SectionHeader}"/>
                                <TextBlock x:Name="BootElapsed" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Visibility="Collapsed" FontFamily="{StaticResource Mono}" FontSize="12"
                                           Foreground="{StaticResource Warn}"/>
                                <StackPanel x:Name="ReadyBadge" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Visibility="Collapsed">
                                    <Path Data="{StaticResource IcoCheck}" Stroke="{StaticResource Ok}" StrokeThickness="2.2"
                                          Width="14" Height="14" Stretch="Uniform"/>
                                    <TextBlock Text="Готов к печати" Margin="6,0,0,0" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Ok}"/>
                                </StackPanel>
                            </Grid>

                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="VmDot" Grid.Column="0" Style="{StaticResource DotOff}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Виртуальная машина" Margin="12,0,0,0"
                                               VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium"/>
                                    <TextBlock x:Name="VmState" Grid.Column="2" Text="Остановлена" VerticalAlignment="Center"
                                               FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Off}"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="OsDot" Grid.Column="0" Style="{StaticResource DotOff}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium">
                                        <Run Text="Образ ОС"/><Run Text="  (Windows XP)" FontFamily="{StaticResource Mono}"
                                             FontSize="12.5" FontWeight="Normal" Foreground="{StaticResource Tx3}"/>
                                    </TextBlock>
                                    <TextBlock x:Name="OsState" Grid.Column="2" Text="Не запущен" VerticalAlignment="Center"
                                               FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Off}"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="PrDot" Grid.Column="0" Style="{StaticResource DotOff}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium">
                                        <Run Text="Принтер"/><Run Text="  Canon LBP-1120" FontFamily="{StaticResource Mono}"
                                             FontSize="12.5" FontWeight="Normal" Foreground="{StaticResource Tx3}"/>
                                    </TextBlock>
                                    <TextBlock x:Name="PrState" Grid.Column="2" Text="Неизвестно" VerticalAlignment="Center"
                                               FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Off}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Print params -->
                    <Border Style="{StaticResource CardPanel}" Padding="14" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="ПАРАМЕТРЫ ПЕЧАТИ" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Формат" Style="{StaticResource FieldLabel}"/>
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="PaperBox" Grid.Column="0" IsEnabled="False" SelectedIndex="0"
                                              ToolTip="только A4 — очередь Canon LBP-1120">
                                        <ComboBoxItem Content="A4"/>
                                    </ComboBox>
                                    <TextBlock Grid.Column="1" Text="только A4" VerticalAlignment="Center" Margin="10,0,0,0"
                                               FontSize="11.5" Foreground="{StaticResource Tx3}"
                                               ToolTip="только A4 — очередь Canon LBP-1120"/>
                                </Grid>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Копии" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="CopiesBox" Grid.Row="1" Grid.Column="1" Text="1" Width="118"
                                         HorizontalAlignment="Left" Margin="0,0,0,11" MaxLength="4"
                                         PreviewTextInput="Integer_PreviewTextInput"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Масштаб" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="ScaleBox" Grid.Row="2" Grid.Column="1" SelectedIndex="0">
                                    <ComboBoxItem Content="Вписать в страницу" Tag="fit"/>
                                    <ComboBoxItem Content="Как есть" Tag="noscale"/>
                                    <ComboBoxItem Content="Уменьшить при необходимости" Tag="shrink"/>
                                </ComboBox>
                            </Grid>

                            <!-- Дополнительно -->
                            <Expander Margin="0,12,0,0" Background="Transparent" BorderThickness="0">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Дополнительно" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Tx2}"/>
                                        <TextBlock Text="— страницы, порядок" FontFamily="{StaticResource Mono}"
                                                   FontSize="11.5" Foreground="{StaticResource Tx3}" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Expander.Header>
                                <Grid Margin="13,12,13,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Страницы" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="PagesBox" Grid.Column="1" TextChanged="PagesBox_TextChanged"
                                             ToolTip="Пусто = все. Примеры: 1-4 или 1,3,5-8"/>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- Info banner -->
                    <Border Background="{StaticResource InfoBg}" BorderBrush="{StaticResource InfoBd}"
                            BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IcoInfo}" Stroke="{StaticResource Accent}" StrokeThickness="1.8"
                                  Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock TextWrapping="Wrap" Margin="10,0,0,0" MaxWidth="360" FontSize="12.5"
                                       Foreground="{StaticResource Tx2}"
                                       Text="Всё готово. По кнопке «Печать» задание уйдёт в очередь; «Готово» покажется только после фактического окончания печати."/>
                        </StackPanel>
                    </Border>

                    <!-- Progress row -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="Busy" Grid.Column="0" VerticalAlignment="Center" IsIndeterminate="False"/>
                        <TextBlock x:Name="StatusText" Grid.Column="1" Margin="12,0,2,0" VerticalAlignment="Center"
                                   MinWidth="120" TextAlignment="Right" Foreground="{StaticResource Tx2}"
                                   FontFamily="{StaticResource Mono}" FontSize="12.5" Text=""/>
                    </Grid>

                    <!-- Журнал -->
                    <Expander x:Name="LogExpander" Margin="0,14,0,0">
                        <Expander.Header>
                            <Grid Width="360">
                                <TextBlock Text="Журнал" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Tx2}"/>
                                <TextBlock x:Name="LogCount" Text="0 записей" HorizontalAlignment="Right"
                                           FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Tx3}"/>
                            </Grid>
                        </Expander.Header>
                        <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                                 Height="180" VerticalScrollBarVisibility="Auto" Background="#fcfcfd"
                                 FontFamily="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource Tx2}"
                                 Padding="14,10"/>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter x:Name="PreviewSplitter" Grid.Column="1" Width="0" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource Stroke}" ResizeBehavior="PreviousAndNext"/>

            <!-- Preview panel -->
            <Grid x:Name="PreviewPanel" Grid.Column="2" Background="{StaticResource Card}" Visibility="Collapsed"
                  SizeChanged="PreviewPanel_SizeChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Height="42" Background="{StaticResource Card2}" BorderBrush="{StaticResource Stroke}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IcoDoc}" Stroke="{StaticResource Tx2}" StrokeThickness="1.5"
                                  Width="15" Height="15" Stretch="Uniform"/>
                            <TextBlock x:Name="PreviewTitle" Text="Предпросмотр" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Tx2}"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Margin="0,0,34,0" VerticalAlignment="Center"
                                Background="{StaticResource OffBg}" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="WebView2 · Edge" FontFamily="{StaticResource Mono}" FontSize="11"
                                       Foreground="{StaticResource Tx3}"/>
                        </Border>
                        <Button Style="{StaticResource IconButton}" Width="28" Height="28" HorizontalAlignment="Right"
                                Foreground="{StaticResource Tx3}" Click="Preview_Click" ToolTip="Скрыть предпросмотр">
                            <Path Data="{StaticResource IcoClose}" Stroke="{StaticResource Tx3}" StrokeThickness="1.8"
                                  Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <wv2:WebView2 x:Name="PreviewWeb"/>
                    <TextBlock x:Name="PreviewPlaceholder" Text="Предпросмотр" FontSize="14"
                               Foreground="{StaticResource Tx3}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>

                <Border Grid.Row="2" Height="34" Background="{StaticResource Card2}" BorderBrush="{StaticResource Stroke}"
                        BorderThickness="0,1,0,0">
                    <TextBlock x:Name="PreviewFooter" Text="" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Tx3}"/>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== Footer ===== -->
        <Border Grid.Row="2" Background="{StaticResource Mica}" BorderBrush="{StaticResource Stroke}"
                BorderThickness="0,1,0,0">
            <Grid Height="28" Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="FooterDot" Width="8" Height="8" Fill="{StaticResource Off}"/>
                    <TextBlock x:Name="FooterText" Margin="8,0,0,0" VerticalAlignment="Center"
                               FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Tx3}"
                               Text="Готово · очередь:"/>
                </StackPanel>
                <TextBlock x:Name="VersionText" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Tx3}" Text="v1.0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
